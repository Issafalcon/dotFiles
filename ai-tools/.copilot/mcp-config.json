{
  "mcpServers": {
    "mcphub_fetch": {
      "args": ["run", "-i", "--rm", "mcp/fetch"],
      "command": "docker"
    },
    "mcphub_filesystem": {
      "args": [
        "run",
        "-i",
        "--rm",
        "--mount",
        "type=bind,src=${PATH},dst=/projects",
        "mcp/filesystem",
        "/projects"
      ],
      "command": "docker"
    },
    "mcphub_atlassian": {
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "CONFLUENCE_URL=${CONFLUENCE_URL}",
        "-e",
        "CONFLUENCE_USERNAME=${CONFLUENCE_USERNAME}",
        "-e",
        "CONFLUENCE_API_TOKEN=${CONFLUENCE_API_TOKEN}",
        "-e",
        "JIRA_URL=${JIRA_URL}",
        "-e",
        "JIRA_USERNAME=${JIRA_USERNAME}",
        "-e",
        "JIRA_API_TOKEN=${JIRA_API_TOKEN}",
        "ghcr.io/sooperset/mcp-atlassian:latest"
      ],
      "command": "docker"
    },
    "nvim-mcp": {
      "command": "nvim-mcp",
      "args": [
        "--log-file ",
        ". ",
        "--log-level ",
        "debug ",
        "--connect ",
        "auto"
      ]
    }
  }
}
